# This .gitignore is configured specifically for Unity projects to prevent uploading cache, logs, and temporary files.

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Memory captures
/[Mm]emoryCaptures/

# Asset store packages (untrack downloaded packages)
/[Aa]ssets/AssetStoreTools*

# Autogenerated VS/MD/ReSharper project files
/*.csproj
/*.unityproj
/*.sln
/*.suo
/*.tmp
/*.user
/*.userprefs
/*.pidb
/*.booproj
/*.svd
/*.pdb
/*.opendb
/*.db
/*.slnx
/ED_CarlosRussi.slnx

# Unity crash reports
/CrashReports/

# OS generated files
.DS_Store
Thumbs.db
desktop.ini
build.log
*.mp4
